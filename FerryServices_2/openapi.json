{"info":{"title":"Scottish Ferry Services API","version":"1.0"},"paths":{"/api/services":{"get":{"tags":["Ferry Services API"],"summary":"List services","description":"Returns all visible ferry services with current live status, operator, route and location metadata. Scheduled departures are not embedded in this list response.","operationId":"listServices","responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/ServiceResponse"},"type":"array"}}},"description":""}}}},"/api/services/{serviceID}":{"get":{"tags":["Ferry Services API"],"summary":"Get service detail","description":"Returns one visible service. Pass departuresDate as YYYY-MM-DD to include scheduled ferry departures for that local date.","operationId":"getService","parameters":[{"in":"path","name":"serviceID","required":true,"schema":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"}},{"in":"query","name":"departuresDate","required":false,"schema":{"format":"date","type":"string"}}],"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"$ref":"#/components/schemas/ServiceResponse"}}},"description":""},"400":{"description":"Invalid `departuresDate`"},"404":{"description":"`serviceID` not found"}}}},"/api/installations/{installationID}":{"post":{"tags":["Ferry Services API"],"summary":"Create installation","description":"Registers a mobile app installation for push notifications and returns that installation's saved services.","operationId":"createInstallation","parameters":[{"in":"path","name":"installationID","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json;charset=utf-8":{"schema":{"$ref":"#/components/schemas/CreateInstallationRequest"}}}},"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/ServiceResponse"},"type":"array"}}},"description":""},"400":{"description":"Invalid `body`"},"404":{"description":"`installationID` not found"}}}},"/api/installations/{installationID}/push-status":{"get":{"tags":["Ferry Services API"],"summary":"Get push status","description":"Returns whether push notifications are enabled for the mobile app installation.","operationId":"getPushStatus","parameters":[{"in":"path","name":"installationID","required":true,"schema":{"type":"string"}}],"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"$ref":"#/components/schemas/PushStatus"}}},"description":""},"404":{"description":"`installationID` not found"}}},"post":{"tags":["Ferry Services API"],"summary":"Update push status","description":"Enables or disables push notifications for the mobile app installation.","operationId":"updatePushStatus","parameters":[{"in":"path","name":"installationID","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json;charset=utf-8":{"schema":{"$ref":"#/components/schemas/PushStatus"}}}},"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"$ref":"#/components/schemas/PushStatus"}}},"description":""},"400":{"description":"Invalid `body`"},"404":{"description":"`installationID` not found"}}}},"/api/installations/{installationID}/services":{"get":{"tags":["Ferry Services API"],"summary":"List installation services","description":"Returns the services saved by one mobile app installation.","operationId":"listInstallationServices","parameters":[{"in":"path","name":"installationID","required":true,"schema":{"type":"string"}}],"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/ServiceResponse"},"type":"array"}}},"description":""},"404":{"description":"`installationID` not found"}}},"post":{"tags":["Ferry Services API"],"summary":"Add installation service","description":"Adds a service to one mobile app installation and returns the updated saved service list.","operationId":"addInstallationService","parameters":[{"in":"path","name":"installationID","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json;charset=utf-8":{"schema":{"$ref":"#/components/schemas/AddServiceRequest"}}}},"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/ServiceResponse"},"type":"array"}}},"description":""},"400":{"description":"Invalid `body`"},"404":{"description":"`installationID` not found"}}}},"/api/installations/{installationID}/services/{serviceID}":{"delete":{"tags":["Ferry Services API"],"summary":"Delete installation service","description":"Removes a service from one mobile app installation and returns the updated saved service list.","operationId":"deleteInstallationService","parameters":[{"in":"path","name":"installationID","required":true,"schema":{"type":"string"}},{"in":"path","name":"serviceID","required":true,"schema":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"}}],"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/ServiceResponse"},"type":"array"}}},"description":""},"404":{"description":"`installationID` or `serviceID` not found"}}}},"/api/vessels":{"get":{"tags":["Ferry Services API"],"summary":"List vessels","description":"Returns recent vessel positions used by the live service UI.","operationId":"listVessels","responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/VesselResponse"},"type":"array"}}},"description":""}}}},"/api/timetable-documents":{"get":{"tags":["Ferry Services API"],"summary":"List timetable documents","description":"Returns current operator timetable documents. Pass serviceID to filter to documents linked to one service; omit it for the global timetable downloads screen. Clients should send If-None-Match with the stored ETag; unchanged lists return 304 Not Modified.","operationId":"listTimetableDocuments","parameters":[{"in":"query","name":"serviceID","required":false,"schema":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"}},{"in":"header","name":"If-None-Match","required":false,"schema":{"type":"string"}}],"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/TimetableDocumentResponse"},"type":"array"}}},"description":"","headers":{"Cache-Control":{"schema":{"type":"string"}},"ETag":{"schema":{"type":"string"}}}},"400":{"description":"Invalid `If-None-Match` or `serviceID`"}}}},"/api/offline/snapshot.json":{"get":{"tags":["Ferry Services API"],"summary":"Download offline snapshot","description":"Returns the generated offline timetable snapshot. Clients should send If-None-Match with the stored ETag; unchanged snapshots return 304 Not Modified. The response is CDN-cacheable and includes Cache-Control, ETag and Last-Modified headers.","operationId":"getOfflineSnapshot","parameters":[{"in":"header","name":"If-None-Match","required":false,"schema":{"type":"string"}}],"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"$ref":"#/components/schemas/OfflineSnapshot"}}},"description":"","headers":{"Cache-Control":{"schema":{"type":"string"}},"ETag":{"schema":{"type":"string"}},"Last-Modified":{"schema":{"type":"string"}}}},"400":{"description":"Invalid `If-None-Match`"}}}}},"components":{"schemas":{"ServiceResponse":{"properties":{"additional_info":{"type":"string"},"area":{"type":"string"},"disruption_reason":{"type":"string"},"last_updated_date":{"$ref":"#/components/schemas/UTCTime"},"locations":{"items":{"$ref":"#/components/schemas/LocationResponse"},"type":"array"},"operator":{"$ref":"#/components/schemas/OrganisationResponse"},"route":{"type":"string"},"scheduled_departures_available":{"type":"boolean"},"service_id":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"status":{"$ref":"#/components/schemas/ServiceStatus"},"timetable_documents":{"items":{"$ref":"#/components/schemas/TimetableDocumentResponse"},"type":"array"},"updated":{"$ref":"#/components/schemas/UTCTime"},"vessels":{"items":{"$ref":"#/components/schemas/VesselResponse"},"type":"array"}},"required":["service_id","area","route","status","locations","vessels","updated"],"type":"object"},"ServiceStatus":{"enum":[0,1,2,-99],"type":"integer"},"LocationResponse":{"properties":{"id":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"latitude":{"type":"number"},"longitude":{"type":"number"},"name":{"type":"string"},"next_departure":{"$ref":"#/components/schemas/DepartureResponse"},"next_rail_departure":{"$ref":"#/components/schemas/RailDepartureResponse"},"scheduled_departures":{"items":{"$ref":"#/components/schemas/DepartureResponse"},"type":"array"},"weather":{"$ref":"#/components/schemas/LocationWeatherResponse"}},"required":["id","name","latitude","longitude"],"type":"object"},"DepartureResponse":{"properties":{"arrival":{"$ref":"#/components/schemas/UTCTime"},"departure":{"$ref":"#/components/schemas/UTCTime"},"destination":{"$ref":"#/components/schemas/LocationResponse"},"notes":{"type":"string"}},"required":["destination","departure","arrival"],"type":"object"},"UTCTime":{"example":"2016-07-22T00:00:00Z","format":"date-time","type":"string"},"RailDepartureResponse":{"properties":{"departure":{"$ref":"#/components/schemas/UTCTime"},"departure_info":{"type":"string"},"from":{"type":"string"},"is_cancelled":{"type":"boolean"},"platform":{"type":"string"},"to":{"type":"string"}},"required":["from","to","departure","departure_info","is_cancelled"],"type":"object"},"LocationWeatherResponse":{"properties":{"description":{"type":"string"},"icon":{"type":"string"},"temperature_celsius":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"wind_direction":{"type":"number"},"wind_direction_cardinal":{"type":"string"},"wind_speed_mph":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"}},"required":["icon","description","temperature_celsius","wind_speed_mph","wind_direction","wind_direction_cardinal"],"type":"object"},"VesselResponse":{"properties":{"course":{"type":"number"},"last_received":{"$ref":"#/components/schemas/UTCTime"},"latitude":{"type":"number"},"longitude":{"type":"number"},"mmsi":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"name":{"type":"string"},"speed":{"type":"number"}},"required":["mmsi","name","latitude","longitude","last_received"],"type":"object"},"OrganisationResponse":{"properties":{"email":{"type":"string"},"facebook":{"type":"string"},"id":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"international_number":{"type":"string"},"local_number":{"type":"string"},"name":{"type":"string"},"website":{"type":"string"},"x":{"type":"string"}},"required":["id","name"],"type":"object"},"TimetableDocumentResponse":{"properties":{"content_hash":{"type":"string"},"content_length":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"content_type":{"type":"string"},"id":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"last_seen_at":{"$ref":"#/components/schemas/UTCTime"},"organisation_id":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"organisation_name":{"type":"string"},"service_ids":{"items":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"type":"array"},"source_url":{"type":"string"},"title":{"type":"string"},"updated":{"$ref":"#/components/schemas/UTCTime"}},"required":["id","organisation_id","organisation_name","service_ids","title","source_url","last_seen_at","updated"],"type":"object"},"CreateInstallationRequest":{"properties":{"device_token":{"type":"string"},"device_type":{"$ref":"#/components/schemas/DeviceType"}},"required":["device_token","device_type"],"type":"object"},"DeviceType":{"enum":["IOS","Android"],"type":"string"},"PushStatus":{"properties":{"enabled":{"type":"boolean"}},"required":["enabled"],"type":"object"},"AddServiceRequest":{"properties":{"service_id":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"}},"required":["service_id"],"type":"object"},"OfflineSnapshot":{"description":"Generated offline timetable snapshot. This is static timetable/reference data for local device caching; live status, disruptions, vessels, weather and push installation state are intentionally excluded.","example":{"data_version":"sha256-abc123","departures":[],"generated_at":"2026-05-02T10:00:00Z","locations":[],"organisations":[],"schema_version":1,"services":[],"timetable_documents":[],"valid_from":"2026-05-02","valid_to":"2026-06-30"},"properties":{"data_version":{"description":"Stable SHA-256 version for the snapshot content. Also used as the ETag value without surrounding quotes.","type":"string"},"departures":{"description":"Generated scheduled ferry departures for the snapshot validity window.","items":{"$ref":"#/components/schemas/OfflineDeparture"},"type":"array"},"generated_at":{"$ref":"#/components/schemas/UTCTime"},"locations":{"description":"Location lookup table. Services and departures reference these rows by id.","items":{"$ref":"#/components/schemas/OfflineLocation"},"type":"array"},"organisations":{"description":"Operator lookup table. Services reference these rows by organisation_id.","items":{"$ref":"#/components/schemas/OfflineOrganisation"},"type":"array"},"schema_version":{"description":"Snapshot schema version. Increment this when clients need a migration path.","maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"services":{"description":"Visible ferry services included in the offline cache.","items":{"$ref":"#/components/schemas/OfflineService"},"type":"array"},"timetable_documents":{"description":"Current operator timetable documents available for offline catalogue/bootstrap use.","items":{"$ref":"#/components/schemas/TimetableDocumentResponse"},"type":"array"},"valid_from":{"$ref":"#/components/schemas/Day"},"valid_to":{"$ref":"#/components/schemas/Day"}},"required":["schema_version","data_version","generated_at","valid_from","valid_to","services","locations","organisations","timetable_documents","departures"],"type":"object"},"Day":{"example":"2016-07-22","format":"date","type":"string"},"OfflineService":{"description":"Offline service row. This is deliberately normalized for compact storage.","example":{"area":"Arran","id":5,"location_ids":[4,5],"organisation_id":1,"route":"Ardrossan - Brodick","scheduled_departures_available":true},"properties":{"area":{"description":"Geographic service grouping shown in the app.","type":"string"},"id":{"description":"Service id used by existing live API responses.","maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"location_ids":{"description":"Ordered location ids served by this service; resolve via locations[].id.","items":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"type":"array"},"organisation_id":{"description":"Operator id; resolve via organisations[].id.","maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"route":{"description":"Human-readable route name.","type":"string"},"scheduled_departures_available":{"description":"Whether scheduled TransXChange departures are available for this service.","type":"boolean"}},"required":["id","area","route","organisation_id","location_ids","scheduled_departures_available"],"type":"object"},"OfflineLocation":{"description":"Offline location lookup row.","example":{"id":4,"latitude":55.576,"longitude":-5.138,"name":"Brodick"},"properties":{"id":{"description":"Location id used by service location_ids and departure location references.","maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"latitude":{"description":"Latitude in decimal degrees.","type":"number"},"longitude":{"description":"Longitude in decimal degrees.","type":"number"},"name":{"description":"Display name for the port/location.","type":"string"}},"required":["id","name","latitude","longitude"],"type":"object"},"OfflineOrganisation":{"description":"Offline ferry operator lookup row.","example":{"id":1,"name":"CalMac Ferries","website":"https://www.calmac.co.uk"},"properties":{"email":{"description":"Operator contact email address.","type":"string"},"facebook":{"description":"Operator Facebook URL.","type":"string"},"id":{"description":"Organisation/operator id used by services[].organisation_id.","maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"international_number":{"description":"International contact telephone number.","type":"string"},"local_number":{"description":"Local contact telephone number.","type":"string"},"name":{"description":"Operator display name.","type":"string"},"website":{"description":"Operator website.","type":"string"},"x":{"description":"Operator X/Twitter URL or handle.","type":"string"}},"required":["id","name"],"type":"object"},"OfflineDeparture":{"description":"Offline scheduled ferry departure.","example":{"arrival":"2026-05-02T07:55:00Z","departure":"2026-05-02T07:00:00Z","from_location_id":4,"notes":"Check in 30 minutes before departure","service_id":5,"to_location_id":5},"properties":{"arrival":{"$ref":"#/components/schemas/UTCTime"},"departure":{"$ref":"#/components/schemas/UTCTime"},"from_location_id":{"description":"Origin location id; resolve via locations[].id.","maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"notes":{"description":"Optional timetable note/check-in text from the source data.","type":"string"},"service_id":{"description":"Service id for this departure; resolve via services[].id.","maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"to_location_id":{"description":"Destination location id; resolve via locations[].id.","maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"}},"required":["service_id","from_location_id","to_location_id","departure","arrival"],"type":"object"}}},"tags":[{"description":"Live ferry service data, mobile installation state, vessel positions and offline timetable downloads.","name":"Ferry Services API"}],"openapi":"3.0.0"}