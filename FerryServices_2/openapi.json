ry","name":"serviceID","required":false,"schema":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"}},{"in":"header","name":"If-None-Match","required":false,"schema":{"type":"string"}}],"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/TimetableDocumentResponse"},"type":"array"}}},"description":"","headers":{"Cache-Control":{"schema":{"type":"string"}},"ETag":{"schema":{"type":"string"}}}},"400":{"description":"Invalid `If-None-Match` or `serviceID`"}}}},"/api/offline/snapshot.sqlite3":{"get":{"tags":["Ferry Services API"],"summary":"Download offline SQLite snapshot","description":"Returns the generated offline timetable SQLite database. Clients should send If-None-Match with the stored ETag; unchanged snapshots return 304 Not Modified. The response is CDN-cacheable and includes Cache-Control, ETag and Last-Modified headers.","operationId":"getOfflineSnapshot","parameters":[{"in":"header","name":"If-None-Match","required":false,"schema":{"type":"string"}}],"responses":{"200":{"content":{"application/vnd.sqlite3":{"schema":{"$ref":"#/components/schemas/SnapshotBody"}}},"description":"","headers":{"Cache-Control":{"schema":{"type":"string"}},"ETag":{"schema":{"type":"string"}},"Last-Modified":{"schema":{"type":"string"}}}},"400":{"description":"Invalid `If-None-Match`"}}}}},"components":{"schemas":{"ServiceResponse":{"properties":{"additional_info":{"type":"string"},"area":{"type":"string"},"disruption_reason":{"type":"string"},"last_updated_date":{"$ref":"#/components/schemas/UTCTime"},"locations":{"items":{"$ref":"#/components/schemas/LocationResponse"},"type":"array"},"operator":{"$ref":"#/components/schemas/OrganisationResponse"},"route":{"type":"string"},"scheduled_departures_available":{"type":"boolean"},"service_id":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"},"status":{"$ref":"#/components/schemas/ServiceStatus"},"timetable_documents":{