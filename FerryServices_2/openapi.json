{"info":{"title":"Scottish Ferry Services API","version":"1.0"},"paths":{"/api/services":{"get":{"tags":["Ferry Services API"],"summary":"List services","description":"Returns all visible ferry services with current live status, operator, route and location metadata. Scheduled departures are not embedded in this list response.","operationId":"listServices","responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/ServiceResponse"},"type":"array"}}},"description":""}}}},"/api/services/{serviceID}":{"get":{"tags":["Ferry Services API"],"summary":"Get service detail","description":"Returns one visible service. Pass departuresDate as YYYY-MM-DD to include scheduled ferry departures for that local date.","operationId":"getService","parameters":[{"in":"path","name":"serviceID","required":true,"schema":{"maximum":9223372036854775807,"minimum":-9223372036854775808,"type":"integer"}},{"in":"query","name":"departuresDate","required":false,"schema":{"format":"date","type":"string"}}],"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"$ref":"#/components/schemas/ServiceResponse"}}},"description":""},"400":{"description":"Invalid `departuresDate`"},"404":{"description":"`serviceID` not found"}}}},"/api/installations/{installationID}":{"post":{"tags":["Ferry Services API"],"summary":"Create installation","description":"Registers a mobile app installation for push notifications and returns that installation's saved services.","operationId":"createInstallation","parameters":[{"in":"path","name":"installationID","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json;charset=utf-8":{"schema":{"$ref":"#/components/schemas/CreateInstallationRequest"}}}},"responses":{"200":{"content":{"application/json;charset=utf-8":{"schema":{"items":{"$ref":"#/components/schemas/ServiceResponse"},"type":"array"}}},"description":""},"400":{"description":"Invalid `body`"},"404":{"descriptio